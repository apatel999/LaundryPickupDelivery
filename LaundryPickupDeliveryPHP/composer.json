{
    "name": "laundryloop/api-php",
    "description": "LaundryLoop Pickup & Delivery API — Slim 4 + PDO + MySQL",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "slim/slim": "^4.12",
        "slim/psr7": "^1.6",
        "php-di/php-di": "^7.0",
        "monolog/monolog": "^3.5"
    },
    "autoload": {
        "psr-4": {
            "LaundryLoop\\": ["src/", "config/"]
        }
    },
    "config": {
        "optimize-autoloader": true
    }
}